# COT Weekly Report — Email Configuration
# Copy this file to .env and fill in your credentials.
# .env is gitignored and never committed.

# SMTP server (Gmail shown; Outlook: smtp-mail.outlook.com)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Sender credentials
# Gmail: enable 2-Step Verification, then create an App Password at:
#   https://myaccount.google.com/apppasswords
# Use the 16-char app password (no spaces) as EMAIL_PASSWORD.
EMAIL_USER=your.address@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# One or more recipients, comma-separated
EMAIL_TO=you@example.com,colleague@example.com
